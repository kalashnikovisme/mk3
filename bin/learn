#!/usr/bin/env ruby
# PPO self-play training for Mortal Kombat 3.
# Runs indefinitely: play matches → collect trajectories → PPO update → repeat.
# Resumes from the latest checkpoint automatically.
# Press Ctrl+C to stop cleanly.
#
# Environment variables:
#   MATCH=sub-zero-vs-sub-zero   load only that match state (default)
#   ROM_PATH, CORE_PATH          override ROM / libretro core paths

$LOAD_PATH.unshift File.expand_path("../lib", __dir__)

# ── Pre-flight: Python environment ────────────────────────────────────────────
unless system("python3 --version > /dev/null 2>&1")
  abort "ERROR: python3 not found.\nRun `dip provision` to rebuild the image and install all dependencies."
end

unless system("python3 -c 'import torch' > /dev/null 2>&1")
  abort "ERROR: PyTorch is not installed.\nRun `dip provision` to install Python dependencies (pip install -r requirements.txt)."
end

require "fighting_ai/cli/bootstrap"
require_relative "../config/mk3"

ROM_PATH    = ENV.fetch("ROM_PATH",  File.expand_path("../mk3.sfc", __dir__))
CORE_PATH   = ENV.fetch("CORE_PATH", "/usr/lib/x86_64-linux-gnu/libretro/snes9x_libretro.so")
MATCHES_DIR = File.expand_path("../data/matches", __dir__)
MODELS_DIR  = File.expand_path("../models", __dir__)
MEMORY_DIR  = File.expand_path("../data/memory", __dir__)
WRAM_DEBUG   = ARGV.include?("debug")
# First non-flag argument is the match name, e.g. "sub-zero-vs-sindel"
MATCH_ARG    = ARGV.reject { |a| a == "debug" }.first
MATCH_FILTER = MATCH_ARG || ENV["MATCH"]

OBS_DIM    = 18  # FightingAI::Core::Observation#to_vector element count
ACTION_DIM = FightingAI::Game::MortalKombat3::ActionTranslator::ACTIONS.size

# ── Resolve match state ───────────────────────────────────────────────────────

def parse_match_file(path)
  basename          = File.basename(path, ".state")
  p1_str, p2_str    = basename.split("-vs-", 2)
  { path: path, p1: p1_str.tr("-", "_").to_sym, p2: p2_str.tr("-", "_").to_sym }
end

if WRAM_DEBUG
  FileUtils.mkdir_p(MEMORY_DIR)
  FileUtils.rm_f(Dir.glob("#{MEMORY_DIR}/*"))
end

match_states = Dir.glob(File.join(MATCHES_DIR, "*.state")).sort.map { |f| parse_match_file(f) }
if MATCH_FILTER
  match_states.select! { |m| File.basename(m[:path], ".state") == MATCH_FILTER }
end
raise "No .state files found in #{MATCHES_DIR}" if match_states.empty?

match_state = match_states.first

# Stage state into slot 0 so RetroArch auto-loads it on boot.
states_dir = FightingAI::Emulator::RetroArch::ConfigBuilder::STATES_DIR
FileUtils.mkdir_p(states_dir)
FileUtils.cp(match_state[:path], File.join(states_dir, "#{File.basename(ROM_PATH, '.*')}.state"))

puts FightingAI::CLI::BANNER
puts "Mode: PPO Self-Play Training\n\n"
puts "Match  → #{File.basename(match_state[:path])}"
puts "Models → #{MODELS_DIR}"
puts "Obs dim: #{OBS_DIM}  |  Actions: #{ACTION_DIM}"
puts "WRAM debug: #{WRAM_DEBUG ? "ON → #{MEMORY_DIR}" : "off"}\n\n"

# ── Signal handling ───────────────────────────────────────────────────────────

trainer_ref = nil
FightingAI::CLI.trap_sigint(cleanup: -> { trainer_ref&.stop })

# ── Start emulator ────────────────────────────────────────────────────────────

emulator = FightingAI::CLI.start_retro_arch(
  rom_path:         ROM_PATH,
  core_path:        CORE_PATH,
  extra_watch_dirs: [MATCHES_DIR]
)

# ── Build game adapter with RL reward weights ─────────────────────────────────

game = FightingAI.build_mk3_adapter(
  emulator_adapter: emulator,
  reward_weights:   FightingAI::Game::RewardCalculator.weights
)

# ── Build training components ─────────────────────────────────────────────────

policy     = FightingAI::Training::Policy.new(obs_dim: OBS_DIM, action_dim: ACTION_DIM)
buffer     = FightingAI::Training::TrajectoryBuffer.new(min_size: 512)
checkpoint = FightingAI::Training::CheckpointManager.new(dir: MODELS_DIR)
translator = FightingAI::Game::MortalKombat3::ActionTranslator

agents = {
  1 => FightingAI::Agent::PPOAgent.new(
    player_index:      1,
    policy:            policy,
    action_translator: translator,
    buffer:            buffer
  ),
  2 => FightingAI::Agent::PPOAgent.new(
    player_index:      2,
    policy:            policy,
    action_translator: translator,
    buffer:            buffer
  )
}

trainer = FightingAI::Training::PPOTrainer.new(
  emulator:           emulator,
  game:               game,
  policy:             policy,
  buffer:             buffer,
  checkpoint_manager: checkpoint,
  agents:             agents,
  match_state:        match_state,
  logger:             FightingAI::CLI.logger("PPO"),
  wram_dump:          WRAM_DEBUG
)
trainer_ref = trainer

# ── Run ───────────────────────────────────────────────────────────────────────

trainer.train
emulator.stop
